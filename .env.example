# 复制为 .env 并填入真实值。ZHIPU_API_KEY 与你的 Claude Code / pi 共用同一把智谱 key。

# === 智谱（GLM + Embedding）===
ZHIPU_API_KEY=your_zhipu_key_here
ZHIPU_LLM_MODEL=glm-5.2
ZHIPU_LLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
ZHIPU_EMBED_MODEL=embedding-3
ZHIPU_EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBED_DIM=2048

# === 基础设施（默认与 docker-compose 一致；本机直连用 localhost）===
DATABASE_URL=postgresql+psycopg://kb:kb_dev_pwd@localhost:5432/kb
ES_URL=http://localhost:9200
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=kb
MINIO_SECRET_KEY=kb_dev_pwd
MINIO_BUCKET=kb-objects
REDIS_URL=redis://localhost:6379/0

# === 服务 ===
KB_API_KEY=kb_dev_api_key
KB_BACKEND_URL=http://localhost:8000
# pi 扩展委托身份（MVP 单租户：固定一个 user）
KB_USER_ID=u_demo
